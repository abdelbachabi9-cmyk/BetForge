        "url": "=https://api.telegram.org/bot{{ $env.TELEGRAM_BOT_TOKEN }}/getFile?file_id={{ $json.message.document ? $json.message.document.file_id : '' }}",
        "authentication": "none",
        "options": {}
      },
      "id": "get-document-file",
      "name": "Get Document File Path",
