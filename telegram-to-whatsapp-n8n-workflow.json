      "id": "check-video",
      "name": "Has Video?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 880]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $env.WHATSAPP_PHONE_NUMBER_ID }}/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  \"messaging_product\": \"whatsapp\",\n  \"to\": $env.WHATSAPP_GROUP_ID || $env.WHATSAPP_RECIPIENT_NUMBER,\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"📨 *\" + ($json.message.from.first_name || 'Utilisateur') + ($json.message.from.last_name ? ' ' + $json.message.from.last_name : '') + \"* (Telegram):\\n\\n\" + ($json.message.text || '[Message sans texte]')\n  }\n}) }}",
        "options": {}
      },
      "id": "send-text-whatsapp",
      "name": "Send Text to WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "WHATSAPP_AUTH_CREDENTIAL_ID",
          "name": "WhatsApp Bearer Token"
        }
      }
    },
    {
      "parameters": {
        "url": "=https://api.telegram.org/bot{{ $env.TELEGRAM_BOT_TOKEN }}/getFile?file_id={{ $json.message.photo ? $json.message.photo[$json.message.photo.length - 1].file_id : '' }}",
        "authentication": "none",
        "options": {}
      },
      "id": "get-photo-file",
      "name": "Get Photo File Path",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 60]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $env.WHATSAPP_PHONE_NUMBER_ID }}/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  \"messaging_product\": \"whatsapp\",\n  \"to\": $env.WHATSAPP_GROUP_ID || $env.WHATSAPP_RECIPIENT_NUMBER,\n  \"type\": \"image\",\n  \"image\": {\n    \"link\": \"https://api.telegram.org/file/bot\" + $env.TELEGRAM_BOT_TOKEN + \"/\" + $json.result.file_path,\n    \"caption\": \"📨 *\" + ($('Telegram Trigger').item.json.message.from.first_name || 'Utilisateur') + \"* (Telegram)\" + ($('Telegram Trigger').item.json.message.caption ? ':\\n' + $('Telegram Trigger').item.json.message.caption : '')\n  }\n}) }}",
        "options": {}
      },
      "id": "send-photo-whatsapp",
      "name": "Send Photo to WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 60],
      "credentials": {
        "httpHeaderAuth": {
          "id": "WHATSAPP_AUTH_CREDENTIAL_ID",
          "name": "WhatsApp Bearer Token"
        }
      }
    },
    {
