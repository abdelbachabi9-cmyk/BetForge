# ============================================================
# .env.example — Variables d'environnement APEX Bot
# Copiez ce fichier en .env pour les tests locaux
# Sur Railway, ajoutez ces variables dans Settings > Variables
# ============================================================

# ── OBLIGATOIRE ─────────────────────────────────────────────
# Token obtenu via @BotFather sur Telegram
TELEGRAM_TOKEN=8655664704:AAH8y98_5jqTomoO78k5zXxZh9anIO3HKwk

# ID du chat ou canal pour l'envoi automatique quotidien
# Pour obtenir votre chat ID : envoyez un message au bot puis
# visitez https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=1531105591

# ── OPTIONNEL ────────────────────────────────────────────────
# Heure d'envoi automatique du coupon (format 24h)
BOT_SEND_HOUR=8
BOT_SEND_MINUTE=0

# Fuseau horaire (liste : https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=Europe/Paris

# Mode démo (true = données simulées, false = APIs réelles)
DEMO_MODE=false

# ── CLÉS API SPORTIVES (optionnel, pour données réelles) ─────
# football-data.org (gratuit sur football-data.org/client/register)
# FOOTBALL_DATA_KEY=votre_cle_ici

# the-odds-api.com (gratuit sur the-odds-api.com/#get-access)
# ODDS_API_KEY=votre_cle_ici
