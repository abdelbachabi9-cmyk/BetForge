# ============================================================
# .env.example — Variables d'environnement APEX Bot v2.0
# ============================================================
# Copier ce fichier en .env et remplir les valeurs.
# Ne JAMAIS commiter le fichier .env (voir .gitignore).
# Sur Railway : configurer dans Settings > Variables.
# ============================================================

# --- OBLIGATOIRE ------------------------------------------
# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_TOKEN=your_telegram_token_here

# --- OPTIONNEL (mais recommande en production) ------------
# ID du chat/canal pour l'envoi automatique quotidien
TELEGRAM_CHAT_ID=

# IDs Telegram autorises (separes par virgule). Vide = ouvert a tous.
ALLOWED_USERS=

# --- APIS SPORTIVES (toutes optionnelles) -----------------
# football-data.org - fixtures et standings
FOOTBALL_DATA_KEY=

# the-odds-api.com - cotes bookmaker reelles
ODDS_API_KEY=

# api-football (RapidAPI) - stats avancees (corners, tirs, etc.)
API_FOOTBALL_KEY=

# BallDontLie - stats NBA (optionnel, tier public disponible sans cle)
BALLDONTLIE_API_KEY=

# --- CONFIGURATION DU BOT ---------------------------------
# Mode demo : true = donnees simulees, false = APIs reelles
DEMO_MODE=false

# Heure d'envoi automatique (0-23, defaut : 8)
BOT_SEND_HOUR=8

# Minute d'envoi automatique (0-59, defaut : 0)
BOT_SEND_MINUTE=0

# Timezone pour le job planifie (defaut : Europe/Paris)
TIMEZONE=Europe/Paris

# --- MODULES OPTIONNELS -----------------------------------
# Chemin du fichier de ratings ELO NBA pre-entraines
ELO_RATINGS_FILE=nba_elo_ratings.json

# Chemin du fichier SQLite (necessite database.py)
DB_PATH=apex.db

# Activer la persistance SQLite (true/false)
DB_ENABLED=true
