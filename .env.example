# ============================================================
# .env.example — Variables d'environnement APEX Bot v2.0
# Copier ce fichier en .env et remplir les valeurs
# JAMAIS committer le fichier .env avec les vraies valeurs
# ============================================================

# --- OBLIGATOIRE ---
TELEGRAM_TOKEN=          # Token du bot via @BotFather — crash au démarrage si absent

# --- ENVOI AUTOMATIQUE ---
TELEGRAM_CHAT_ID=        # ID du canal/chat pour l'envoi quotidien automatique
BOT_SEND_HOUR=8          # Heure d'envoi (0-23), défaut 08h00
BOT_SEND_MINUTE=0        # Minute d'envoi (0-59)
TIMEZONE=Europe/Paris    # Timezone du job planifié

# --- CONTRÔLE D'ACCÈS ---
ALLOWED_USERS=           # IDs Telegram autorisés séparés par virgule (vide = ouvert à tous)

# --- APIs SPORTIVES ---
FOOTBALL_DATA_KEY=       # football-data.org — fixtures et classements football
ODDS_API_KEY=            # the-odds-api.com — cotes bookmaker réelles
API_FOOTBALL_KEY=        # api-football (RapidAPI) — stats avancées (corners, tirs)
BALLDONTLIE_API_KEY=     # BallDontLie — stats NBA (optionnel, tier public sans clé)

# --- MODE DÉMO ---
DEMO_MODE=false          # true = données simulées, false = APIs réelles

# --- BASKETBALL (optionnel) ---
ELO_RATINGS_FILE=nba_elo_ratings.json  # Chemin vers les ratings ELO NBA pré-entraînés

# --- BACKTESTING ---
BACKTEST_HISTORY_FILE=coupon_history.json  # Fichier JSON historique des coupons
BACKTEST_AUTO_TRACK=true                   # Enregistrer automatiquement chaque coupon

# --- BASE DE DONNÉES SQLite ---
DB_PATH=apex.db    # Chemin du fichier SQLite (nécessite database.py)
DB_ENABLED=true    # Activer la persistance SQLite

# --- LINE MOVEMENT (optionnel) ---
LINE_MOVEMENT_ENABLED=false  # Suivi des mouvements de cotes bookmaker
