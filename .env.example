# ══════════════════════════════════════════════════════════════
#   APEX — BetForge : Variables d'environnement
#   Copiez ce fichier en .env et remplissez vos vraies valeurs
# ══════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Planification envoi automatique ─────────────────────────
BOT_SEND_HOUR=8
BOT_SEND_MINUTE=0
TIMEZONE=Africa/Porto-Novo

# ── Mode ─────────────────────────────────────────────────────
DEMO_MODE=false

# ── Clés API sportives ───────────────────────────────────────
FOOTBALL_DATA_KEY=your_football_data_api_key_here
ODDS_API_KEY=your_odds_api_key_here
API_FOOTBALL_KEY=your_rapidapi_key_here

# ── Persistance & Backtesting (v2.0) ────────────────────────
APEX_DB_PATH=apex_history.db
APEX_AUTO_SAVE=true
LINE_MOVEMENT_ENABLED=true
BACKTEST_AUTO_TRACK=true

# ── Utilisateurs autorisés (optionnel) ──────────────────────
# ALLOWED_USERS=123456789,987654321
